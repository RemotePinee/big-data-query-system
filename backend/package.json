  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "test": "jest",
    "test:silent": "cross-env TEST_LOG_LEVEL=silent jest --silent --maxWorkers=1",
