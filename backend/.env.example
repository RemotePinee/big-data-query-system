# ===========================================
# 大数据查询系统 - 环境变量配置示例
# ===========================================
# 请复制此文件为 .env 并根据实际情况修改配置

# ===========================================
# 基础服务配置
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# 域名配置（生产环境必须修改）
# ===========================================
FRONTEND_URL=http://localhost:5176
API_BASE_URL=http://localhost:3000/api

# 生产环境示例：
# FRONTEND_URL=https://your-domain.com
# API_BASE_URL=https://your-domain.com/api

# ===========================================
# 数据库配置（必须配置）
# ===========================================
DB_HOST=localhost:3306
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=your_database_name

# ===========================================
# JWT配置（必须配置强密钥）
# ===========================================
# 请生成你自己的安全密钥！
# 可以使用: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_secure_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ===========================================
# Redis缓存配置（推荐配置）
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# 支付回调URL配置（自动使用API_BASE_URL变量）
# ===========================================
WECHAT_NOTIFY_URL=.env{API_BASE_URL}/payments/notify/wechat
ALIPAY_NOTIFY_URL=.env{API_BASE_URL}/payments/notify/alipay
EPAY_NOTIFY_URL=.env{API_BASE_URL}/payments/notify/epay

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
LOG_DIR=./logs

# 日志级别说明：
# - error: 只记录错误
# - warn: 记录警告和错误
# - info: 记录信息、警告和错误（推荐）
# - debug: 记录所有日志（开发时使用）

# ===========================================
# 限流配置
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 限流说明：
# RATE_LIMIT_WINDOW_MS: 时间窗口（毫秒），默认15分钟
# RATE_LIMIT_MAX_REQUESTS: 时间窗口内最大请求数

# ===========================================
# 可选的支付配置（如需要可以添加）
# ===========================================
# 注意：支付配置建议在后台管理界面配置，更安全
# 以下配置仅在特殊需求时使用

# 微信支付（可选）
# WECHAT_APP_ID=your_wechat_app_id
# WECHAT_APP_SECRET=your_wechat_app_secret
# WECHAT_MERCHANT_ID=your_merchant_id

# 支付宝（可选）
# ALIPAY_APP_ID=your_alipay_app_id
# ALIPAY_PRIVATE_KEY=your_private_key

# 易支付（可选）
# EPAY_API_URL=your_epay_api_url
# EPAY_MERCHANT_ID=your_epay_merchant_id
# EPAY_API_KEY=your_epay_api_key

# ===========================================
# 配置说明
# ===========================================
# 1. 必须配置项：数据库、JWT密钥、域名
# 2. 推荐配置项：Redis、日志级别
# 3. 支付回调URL会自动使用API_BASE_URL变量
# 4. 生产环境请务必修改域名配置
# 5. 详细的支付配置建议在后台管理界面配置
